# User configuration

# export LANG=en_US.UTF-8

# Preferred editor for local and remote sessions
# if [[ -n $SSH_CONNECTION ]]; then
#   export EDITOR='vim'
# else
#   export EDITOR='nvim'
# fi

export EDITOR=nvim
export VISUAL=nvim

# 履歴ファイルのパス（デフォルトは ~/.zsh_history）
HISTFILE=~/.zsh_history

# メモリに保持する履歴の最大数
HISTSIZE=100

# 履歴ファイルに保存する最大コマンド数
SAVEHIST=10000

# 履歴を追記モードで保存（上書きしない）
setopt APPEND_HISTORY

# 複数の Zsh セッション間で履歴を即座に共有（オプション）
setopt SHARE_HISTORY

# 重複コマンドを履歴に追加しない（オプション）
setopt HIST_IGNORE_DUPS

# スペースで始まるコマンドを履歴に残さない（オプション）
setopt HIST_IGNORE_SPACE

# snapパッケージへのパスを通す
export PATH="$PATH:/snap/bin"

#windowsのクリップボードへコピ
alias clip='/mnt/c/WINDOWS/system32/clip.exe'

# Rust
. "$HOME/.cargo/env"

# Haskell
[ -f "$HOME/.ghcup/env" ] && . "$HOME/.ghcup/env" # ghcup-env
export PATH=$PATH:~/.local/bin/

# ref [WSL2でtmux/vimのクリップボードをwinと共有する設定](https://zenn.dev/kujirahand/articles/4b37160f781be7)
export PATH=$HOME/mybin:$PATH

# Goのインストールディレクトリを指定
export GOROOT=$HOME/go

# Goのプロジェクトやパッケージを管理するワークスペースを指定
export GOPATH=$HOME/go-work

# Goコマンドへのパスを通す
export PATH=$PATH:$GOROOT/bin:$GOPATH/bin

# vi mode on
bindkey -v

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"                   # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion" # This loads nvm bash_completion

# https://github.com/zsh-users/zsh-autosuggestions
source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh

# https://github.com/zsh-users/zsh-syntax-highlighting
source /home/wanchiwanpu/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# https://github.com/starship/starship/blob/master/docs%2Fja-JP%2Fguide%2FREADME.md
eval "$(starship init zsh)"

# [Installation | Task](https://taskfile.dev/docs/installation#setup-completions)
# ~/.zshrc
eval "$(task --completion zsh)"

# [Installation](https://docs.deno.com/runtime/getting_started/installation/)
. "/home/wanchiwanpu/.deno/env"
